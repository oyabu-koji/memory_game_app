{
  "name": "memory-game-app",
  "version": "0.1.0",
  "description": "React Native + Expo memory game application",
  "private": true,
  "main": "expo/AppEntry",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "lint": "eslint .",
    "format": "npx prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "expo",
    "react-native",
    "memory-game"
  ],
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "typescript": "~5.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.0",
    "@testing-library/react-native": "^13.3.3",
    "expo": "54",
    "expo-av": "~16.0.8",
    "expo-haptics": "~15.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-test-renderer": "19.1.0"
  }
}
